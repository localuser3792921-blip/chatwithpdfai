# =================================================================
# CHATWITHPDFAI.COM — Environment variables template
# =================================================================
#
# This file is COMMITTED to git as a template. The real values go in:
#   - On Hostinger: hPanel → Websites → chatwithpdfai.com → Environment variables
#   - For local dev: copy this file to .env.local (which IS .gitignored)
#
# NEVER put real passwords/secrets in this file.
# =================================================================

# ---------- Site ----------
SITE_URL=https://chatwithpdfai.com
NODE_ENV=production

# ---------- MySQL ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u692382124_chatwithpdfai
DB_USER=u692382124_chatwithpdf
DB_PASSWORD=replace_with_real_password_in_hostinger_env_vars

# ---------- Email (SMTP via Hostinger) ----------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@chatwithpdfai.com
SMTP_PASSWORD=replace_with_real_password_in_hostinger_env_vars
SMTP_FROM="CHATWITHPDFAI <support@chatwithpdfai.com>"
