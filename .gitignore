# ============================================================
# CHATWITHPDFAI.COM — .gitignore
# Static HTML site deployed to Hostinger via GitHub Actions
# ============================================================

# OS metadata
.DS_Store
Thumbs.db
.thumbnail
desktop.ini
$RECYCLE.BIN/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# Node / build artifacts (if you ever add tooling)
node_modules/
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/
.tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets — NEVER commit these
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
secrets.json
ftp-credentials.txt

# Cowork private operational files — SSH keys, ops notes, credentials (never commit)
.cowork-private/
.cowork-private/**
**/.cowork-private/
**/credentials.env
**/credentials.json
*_ed25519
*_ed25519.pub